{
    "title": "App shortcuts",
    "rules": [
        {
            "description": "Cmd+Shift+A opens Ghostty",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "a",
                        "modifiers": {
                            "mandatory": ["command", "shift"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "shell_command": "open -na \"Ghostty\""
                        }
                    ]
                }
            ]
        }
    ]
}
