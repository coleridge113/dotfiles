{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Cmd+Shift+A opens Ghostty with fixed window size",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "a",
                                    "modifiers": {
                                        "mandatory": ["command", "shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -na \"Ghostty\"; sleep 0.2; osascript -e 'tell application \"System Events\" to tell process \"Ghostty\" to set size of front window to {90, 15}'" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}