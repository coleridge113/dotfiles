let mapleader = " "
set number
set relativenumber
set clipboard=unnamedplus
set ignorecase

nnoremap <leader>ic :set ignorecase!<CR>
nnoremap <leader>q :q<CR>
nnoremap <leader>vv :vsp<CR>
nnoremap <leader>Q :qall<CR>

" Screen motions
nnoremap <leader>wh <C-w>h
nnoremap <leader>wj <C-w>j
nnoremap <leader>wk <C-w>k
nnoremap <leader>wl <C-w>l
nnoremap <leader>ww <C-w>w

call plug#begin('~/.ideaivim/plugged')
Plug 'tpope/vim-surround'
call plug#end()

" Disable the original destructive 's' and 'S' behaviors
" (s = delete-char + insert, S = replace whole line)
nnoremap s <Nop>
nnoremap S <Nop>
xnoremap s <Nop>

" Remap to vim-surround style operations
" Normal-mode: s{motion}{char}  -> like ys{motion}{char}
" Normal-line: S               -> surround whole line (yS)
" Visual-mode: s               -> act like S (wrap selection)
" Delete/change remain standard: ds, cs
nnoremap s ys
nnoremap S yS
xnoremap s S

" Tabbing
nnoremap <C-h> :tabprevious<CR>
nnoremap <C-l> :tabnext<CR>

" Toggle breakpoint
nnoremap <leader>b :action ToggleLineBreakpoint<CR>

" Harpoon
nnoremap <leader>h :action ShowHarpoon<CR>
nnoremap <leader>a :action AddToHarpoon<CR>
nnoremap <leader>1 :action GotoHarpoon1<CR>
nnoremap <leader>2 :action GotoHarpoon2<CR>
nnoremap <leader>3 :action GotoHarpoon3<CR>
nnoremap <leader>4 :action GotoHarpoon4<CR>
nnoremap <leader>5 :action GotoHarpoon5<CR>

" Allow IdeaVim for dialogs
set ideavimsupport+=dialog

" Set quickscope
set quickscope
